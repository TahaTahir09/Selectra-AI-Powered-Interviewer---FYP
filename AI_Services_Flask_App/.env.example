# OpenRouter API Key for Interview Service
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ElevenLabs API Key for Text-to-Speech
# Get your API key from: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs API Key for Speech-to-Text (optional - falls back to ELEVENLABS_API_KEY)
ELEVENLABS_STT_API_KEY=your_elevenlabs_stt_api_key_here

# ElevenLabs Voice ID (optional - defaults to George voice)
# Browse voices at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ElevenLabs Model (optional - defaults to eleven_multilingual_v2)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ElevenLabs STT Model (optional - defaults to scribe_v1)
ELEVENLABS_STT_MODEL_ID=scribe_v1

# ElevenLabs STT Language (optional - defaults to en)
ELEVENLABS_STT_LANGUAGE=en
